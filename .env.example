# Copie ce fichier en .env et remplis les valeurs.

# --- Telegram ---
# 1. Sur Telegram, parle a @BotFather -> /newbot -> recupere le token.
# 2. Pour le chat_id : parle a ton bot (envoie un message), puis ouvre
#    https://api.telegram.org/bot<TON_TOKEN>/getUpdates et lis "chat":{"id":...}
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- Monitoring ---
# Intervalle de check par defaut, en secondes (peut etre surcharge par site dans config.yaml)
CHECK_INTERVAL_SECONDS=180

# Jitter aleatoire ajoute a l'intervalle (en secondes) pour eviter un pattern trop regulier
CHECK_JITTER_SECONDS=45
